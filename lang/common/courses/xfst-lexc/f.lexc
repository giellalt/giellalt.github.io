+Ind+3Sg+3SgO:%>vaa  # ;
+Ind+1Pl+3SgO:%>varput  # ;
+Ind+2Pl+3SgO:%>varsi  # ;
+Ind+3Pl+3SgO:%>vaat  # ;

+Ind+2Sg+1PlO:%>vatsigut  # ;
+Ind+3Sg+1PlO:%>vaatsigut  # ;
+Ind+2Pl+1PlO:%>vatsigut  # ;
+Ind+3Pl+1PlO:%>vaatigut  # ;

+Ind+1Sg+2PlO:%>vassi  # ;
+Ind+3Sg+2PlO:%>vaasi  # ;
+Ind+1Pl+2PlO:%>vassi  # ;
+Ind+3Pl+2PlO:%>vaasi  # ;

+Ind+1Sg+3PlO:%>vakka  # ;
+Ind+2Sg+3PlO:%>vatit  # ;
+Ind+3Sg+3PlO:%>vai  # ;
+Ind+1Pl+3PlO:%>vavut  # ;
+Ind+2Pl+3PlO:%>vasi  # ;
+Ind+3Pl+3PlO:%>vaat  # ;

LEXICON TVint_v
+Int+2Sg+1SgO:%>vinga  # ;
+Int+3Sg+1SgO:%>visinga  # ;
+Int+2Sg+3SgO:%>viuk  # ;
+Int+3Sg+3SgO:%>visuk  # ;

+Int+2Sg+1PlO:%>visigut  # ;
+Int+3Sg+1PlO:%>visigut  # ;
+Int+2Sg+3PlO:%>vigit  # ;
+Int+3Sg+3PlO:%>visigit  # ;







LEXICON TVind_k
+Ind+2Sg+1SgO:%>parma  # ;
+Ind+3Sg+1SgO:%>paanga  # ;
