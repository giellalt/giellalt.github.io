!### Judithes sandkasse
!log: 
!20260326: 3 typer stammer, brug af multikarakter symboler og flags, IV testparadigme og test som var næsten okay hele vejen (se TODO nedenfor).
!TODO: mangelliste i bunden, tjek test_verb_iv.sh qiavoq+V+IV+Ind+3P -> qiapput og *qiavut + Con og Cau 3Pers 4 analyser i stedet for bare 1, prøv med nye stammer: schwa stammer, hent 1 eksempel fra hver IV stammetype fra kal og test





LEXICON verbs_2 
!3 typer stammer: vokalstammer (finalvokal: a, i eller u), historisk set q stammer (vi ser dem kun som r stammeinternt ved verbalstammer), konsonantstammer (historisk set k eller t stammer, altid assimileret ordinternt, ergo ^C)

!IV_r_stem -> flex_iv_r2_inflections
aallarpoq:aallar verb_itr "rejse" ;
ajorpoq:ajor verb_itr "være dårlig" ;
iterpoq:iter verb_itr "vågne" ;

!IV_k_stem -> flex_iv2_inflections
nuuppoq:nuu^C verb_itr "flytte" ; !med forbehold for brug af ^C, siden k-stamme er separeret her
qanippoq:qani^C verb_itr "være nær" ;
tupappoq:tupa^C verb_itr "blive forskrækket" ;

!IV_long_stem -> flex_iv_long2_inflections
kanaarpoq:kanaar verb_itr "slå sig på skinnebenet" ;

!IV_voq_stem -> flex_iv_voq2_inflections
akisuvoq:akisu verb_itr "være dyr" ;
qiavoq:qia verb_itr "græde" ; !test fejl: +V+IV+Ind+3Pl qiapput *qiavut

!XIitX_stem (IV_it_stem) -> flex_iv2_inflections
tikippoq:tiki^C verb_itr "ankomme" ;
!#####
!TODO
!IVschwa
!uerivoq:uer^I verb_itr "være forfalden (til noget)" ; !uerivoq/ueraaq, uerigami, uerimmat, uerippat, ueriguni, uerisoq, uerilluni/ueraluni
!#####

!XIi_voqXmorf_stem -> flex_iv_voq2_inflections
akivoq:aki verb_itr "svare" ; !test fejl: +V+IV+Ind+3Pl akipput *akivut

LEXICON verb_itr
< "@P.itr.ON@" > verb_suffixes ;

LEXICON verb_suffixes
< %+V:0 %+IV:0 "@R.itr.ON@" > verb_moods ;
!verb_to_verb ; !derivatives
!nominalizers ;

LEXICON verb_moods
< "@R.itr.ON@" > verb_itr_moods ;

LEXICON verb_itr_moods !modus og person + numerus skal adskilles, ellers ender vi med at lave et glossarium
!overordnede
+Ind:%>^Vu verb_itr_pers_num ; !^V da den geminerer anderledes (^V -> p p) end den vanlige v -> f f
Imp_mood_itr ;
Int_mood_itr ;
Opt_mood_itr ;
!underordnede
+Cau@P.cau.ON@:@P.cau.ON@%>^Ga verb_itr_pers_num ; !
+Cau@P.3CauCon.ON@:@P.3CauCon.ON@%>^Ma verb_itr_pers_num ; !recessivt m + m, den recessive realiseres ved vokalstammer
+IteCau@P.itecau.ON@:@P.itecau.ON@%>^Gaanga verb_itr_pers_num ;
+Con@P.3CauCon.ON@:@P.3CauCon.ON@%>^Pa verb_itr_pers_num ; !recessivt p + p, den recessive realiseres ved vokalstammer
!IteCau
+Con@P.cond.ON@:@P.cond.ON@%>^Gu verb_itr_pers_num ; 
+Par:%>^TSu verb_itr_pers_num ;
+Cont@P.cont.ON@:@P.cont.ON@%>^Llu verb_itr_pers_num ; !recessivt l + l, den recessive realiseres ved vokalstammer
+ContNeg@P.cont.ON@:@P.cont.ON@%>na verb_itr_pers_num ;
+ContNeg+Alt@P.contnegalt.ON@:@P.contnegalt.ON@%>^G2a verb_itr_pers_num ;

LEXICON verb_itr_pers_num
@D.3CauCon.ON@@D.cond.ON@@D.cau.ON@@D.itecau.ON@@D.contnegalt.ON@ verb_itr_pers_num_Sg ;
@D.3CauCon.ON@@D.cond.ON@@D.cau.ON@@D.itecau.ON@@D.contnegalt.ON@ verb_itr_pers_num_Pl ;
@R.cau.ON@ verb_itr_pers_num_Cau ;
@R.itecau.ON@ verb_itr_pers_num_Cau ;
@R.cond.ON@ verb_itr_pers_num_Cond ;
@R.3CauCon.ON@ pers_num_Cau_Con_3pers ;
@R.itecau.ON@ pers_num_Cau_Con_3pers ;
@R.contnegalt.ON@ pers_num_ContNeg_alt ;

LEXICON verb_itr_pers_num_Sg
+1Sg:%>nga # ;
+2Sg:%>tit # ;
+3Sg@D.cont.ON@:@D.cont.ON@%>q # ;
+4Sg@R.cont.ON@:@R.cont.ON@%>ni # ;

LEXICON verb_itr_pers_num_Pl
+1Pl@D.cont.ON@:@D.cont.ON@%>gut # ;
+1Pl@R.cont.ON@:@R.cont.ON@%>ta # ;
+2Pl:%>si # ;
+3Pl@D.cont.ON@:@D.cont.ON@%>t # ;
+4Pl@R.cont.ON@:@R.cont.ON@%>tik # ;

LEXICON verb_itr_pers_num_Cau
@D.3CauCon.ON@ verb_itr_pers_num_Cau_Sg ;
@D.3CauCon.ON@ verb_itr_pers_num_Cau_Pl ;
@R.3CauCon.ON@@R.itecau.ON@ pers_num_Cau_Con_3pers ;

LEXICON verb_itr_pers_num_Cau_Sg
+1Sg:%>ma # ;
+2Sg:%>vit # ;
+4Sg:%>mi # ;

LEXICON verb_itr_pers_num_Cau_Pl
+1Pl:%>tta # ;
+2Pl:%>ssi # ;
+4Pl:%>mik # ;

LEXICON verb_itr_pers_num_Cond
verb_itr_pers_num_Cond_Sg ;
verb_itr_pers_num_Cond_Pl ;

LEXICON verb_itr_pers_num_Cond_Sg
+1Sg:%>ma # ;
+2Sg:%>it # ;
+4Sg:%>ni # ;

LEXICON verb_itr_pers_num_Cond_Pl
+1Pl:%>tta # ;
+2Pl:%>ssi # ;
+4Pl:%>nik # ;

LEXICON pers_num_Cau_Con_3pers
+3Sg:%>t # ;
+3Pl:%>ta # ;

LEXICON pers_num_ContNeg_alt
+4Sg:ni # ;
+1Pl:ta # ;
+2Pl:si # ;
+4Pl:tik # ;

LEXICON Imp_mood_itr
+Imp+2Sg:%>nak # ; !+Gram/ImpNeg
+Imp+2Sg:%>^G2it # ; !+Gram/ImpPos
+Imp+2Sg:%>na # ;
+Imp+1Pl:%>^TSa # ; 
+Imp+2Pl:%>^G2itsi # ;
!+Imp+2Pl+NNGUUJUIT:%>^Gitsinnguujuit # ;

LEXICON Int_mood_itr
+Int+2Sg:%>^Viit # ; !+Orth/Alt
+Int+2Sg:%>^Vit # ;
+Int+3Sg:%>^Va # ;
+Int+2Pl:%>^Visi # ;
+Int+3Pl:%>^Vat # ;

LEXICON Opt_mood_itr
!+Opt+1Sg:%>naanga # ; !+Orth/Arch+Use/-Spell DANNER mærkelige former
+Opt+1Sg:%>langa # ;
+Opt+3Sg:%>li # ;
+Opt+1Pl:%>lata # ;
!+Opt+1Pl:%>naagut # ; !+Orth/Arch+Use/-Spell DANNER mærkelige former
+Opt+3Pl:%>lit # ;
+Opt+3Pl:%>lik # ; !+Orth/Alt+Use/-Spell




