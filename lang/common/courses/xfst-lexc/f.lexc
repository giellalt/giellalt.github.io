!aja svag "moster" ;
!isi svag "trommeskind" ;
!qimmeq:qimmi QIMMEQ "hund" ;
!nanoq:nanu QIMMEQ "bjørn" ;
!taseq:tasi QIMMEQ "sø" ;
!ukaleq:ukali QIMMEQ "hav" ;
!ameq:ami QIMMEQ "hud" ;
