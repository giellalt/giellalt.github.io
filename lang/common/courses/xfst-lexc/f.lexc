LEXICON Root
nouns ;
verbs ;
verbs_2 ; !20260326 til Judithes sandkasse, separat bare så det er nemmere at overskue og for ikke at ødelægge de eksisterende leksika

LEXICON nouns
illu svag "hus" ;
aja svag "moster" ;
isi svag "trommeskind" ;
qimmeq:qimmi QIMMEQ "hund" ;
nanoq:nanu QIMMEQ "bjørn" ;
taseq:tasi QIMMEQ "sø" ;
ukaleq:ukali QIMMEQ "hav" ;
ameq:ami QIMMEQ "hud" ;
< q e e r l u t o o q "+N":0 "+Abs":0 "+Sg":0 > # ; 

LEXICON verbs
! vokalstammer
anivoq:ani vok_stamme_iv "han går ud" ;
asavara:asa vok_stamme_tv "jeg elsker ham" ;
! konsonantstammer
toquppaa:toqu^C kns_stamme_tv "han dræbar ham" ;
naalappoq:naala^C kns_stamme_tv ;
! r-stammer
ajorpjor r_stamme "det duer ikke" ;


LEXICON svag
tilhæng ;
Kasus ;

 
LEXICON tilhæng
+TUR:%>tor r_stamme ;

LEXICON Kasus
+N+Abs+Sg: # ;
obliq ;

LEXICON obliq
+N+Rel+Sg:%>p # ;
+N+Lok+Sg:%>mi # ;
+N+Ins+Sg:%>mik # ;
+N+Abs+Pl:%>t # ;
+N+Rel+Pl:%>t # ;
+N+Lok+Pl:%>ni # ;
+N+Ins+Pl:%>nik # ;

LEXICON QIMMEQ
+N+Abs+Sg:^GEM%>q # ;
:^GEM obliq ;

LEXICON vok_stamme_iv
+V+IV: IVind_v ; ! indicative
+V+IV: IVint_v ; ! interrogative
+V+TV: TVind_v ; ! indicative
+V+TV: TVint_v ; ! interrogative

LEXICON kns_stamme_iv
+V+IV: vok_stamme_iv ;

LEXICON vok_stamme_tv
+V+TV: TVind_v ; ! indicative
+V+TV: TVint_v ; ! interrogative

LEXICON kns_stamme_tv 
vok_stamme_tv ;

LEXICON r_stamme #;

