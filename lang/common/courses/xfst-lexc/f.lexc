LEXICON Root
!nouns ; !ÆLDRE LEKSIKA - flyttet nederst på filen
!verbs ; !ÆLDRE LEKSIKA - flyttet nederst på filen
nouns_2 ;
verbs_2 ; !20260326 til Judithes sandkasse, separat bare så det er nemmere at overskue og for ikke at ødelægge de eksisterende leksika


!### Judithes sandkasse ###!

!for at genere alle former af en bestemt stamme, gør:
!hfst-fst2strings -X obey-flags f.gen.hfst | grep "uerivoq" 

!### logbog ###! 
!TODO: XItsXmorf_stem tsoq ved Par, og unchecked er schwaet i XIuteXmorf ved derivering
!spekulation: verb_to_verb separat for itr og tr ?, måske lav itr om til IV så det er nemmere at overskue
!### 20260329 dag ###!
!schwa problemet ved Cont løst (*uerilutik)



!#############!
!### NOUNS ###!
!#############!


LEXICON nouns_2 
!svage og stærke stammer
!svage stammer: vokalstamme (a, i, u, ǝ), svag q-stamme, svag k-stamme. 
!stærke stammer: stærk q-stamme, stærk k-stamme, t-stammen (tǝ-stamme for at være præcis)

!#############!
!svage stammer!
!#############!

!vokalstammer
aja svage_suff "moster (fra mors side)" ; !Z1VZmorf -> tpV -> tpV_infl
aqu svage_suff "bagende (af køretøj)" ; !Z1VZmorf
iki svage_suff "sår" ; !Z1VZmorf
illu svage_suff "hus" ; !Z1VZmorf
inǝ svage_suff "rum eller værelse" ; !Z1eZmorf -> Z1eZ -> Z1eZ_inflections

!svage q-stammer
qimmeq svage_suff "hund" ; !Z1iqZmorf "strong i" -> tiqp	(bare 1 medlem i lang-kal!!!)

meeraq svage_suff "barn" ; !Z1+qaZmorf -> Z1_qaZ_inflections (%VCTRUNC brugt i xfst)
!mee^Raq r-et som gemineres som qq fremfor rr

igalaaq svage_suff "vindue" ; !Z1+ssZmorf -> Z1_ssZ_infl (%VCTRUNC igalaat + igalassat)
!igala^Saq latent konsonant imellem dobbetltvokalen, som gemineres til ss ved fleksion

umiatsiaq svage_suff "båd" ; !Z1Zmorf -> tp_infl
!ganske simpel stammefinal konsonant syncope ("truncation") ved fleksion

LEXICON svage_suff !^T ved svage bøjninger
+N:0 poss ; !possessormarkeringer
!+N:^T kasus ;

LEXICON poss
0:^T%< poss_Sg ;
0:^T%< poss_Pl ;
< "@P.possAbsRel.ON@" > poss_kasus ;

LEXICON poss_Sg
< %+1SgPoss:%^CP [ %+Sg:0 | %+Pl:0 ] > poss_kasus_Oblique ;
< %+2SgPoss:%^CP [ %+Sg:0 | %+Pl:0 ] > poss_kasus_Oblique ;
@P.3poss.ON@+3SgPoss+Sg:@P.3poss.ON@a poss_kasus_Oblique ;
@P.3poss.ON@+3SgPoss+Pl:@P.3poss.ON@i poss_kasus_Oblique ; 
< %+4SgPoss:{mi} [ %+Sg:0 | %+Pl:0 ] > poss_kasus_Oblique ;

LEXICON poss_Pl
< %+1PlPoss:{tsi} 0:%^CP [ %+Sg:0 | %+Pl:0 ] > poss_kasus_Oblique ;
< %+2PlPoss:{ssi} 0:%^CP [ %+Sg:0 | %+Pl:0 ] > poss_kasus_Oblique ;
@P.3poss.ON@+3PlPoss+Sg:@P.3poss.ON@a^C poss_kasus_Oblique ;
@P.3poss.ON@+3PlPoss+Pl:@P.3poss.ON@i poss_kasus_Oblique ;
< %+4PlPoss:{mi} 0:%^CP [ %+Sg:0 | %+Pl:0 ] > poss_kasus_Oblique ;

LEXICON poss_kasus
< "@D.possAbsRel.ON@" > poss_kasus_Oblique ;
< "@R.possAbsRel.ON@" > poss_Abs_Rel ;

LEXICON poss_kasus_Oblique
< 0:%< %+Abl:{nit} > # ; !
< 0:%< 0:%^G2 %+Via:{ut} "@D.3poss.ON@" > # ;
< 0:%^T 0:%< %+Via:{tigut} "@R.3poss.ON@" > # ;
< 0:%< %+Aeq:{tut} > # ;
< 0:%< %+Ins:{nik} > # ;
< 0:%< %+Trm:{nut} > # ;
< 0:%< %+Lok:{ni} > # ;

LEXICON poss_Abs_Rel
0:^T%< poss_Abs_Rel_tru ; 
0:%< poss_Abs_Rel_add ;

LEXICON poss_Abs_Rel_add !add som i additive, derivering og evt. assimilation
+1SgPoss+Sg+Abs:^G2a # ; 

LEXICON poss_Abs_Rel_tru !tru som i truncative, finalkonsonant sletning
!Absolutiv
+1SgPoss+Pl+Abs:kka # ;
+1PlPoss+Sg+Abs:rput # ;
+1PlPoss+Pl+Abs:vut # ;
+2SgPoss+Sg+Abs:t # ;
+2SgPoss+Pl+Abs:tit # ;
+2PlPoss+Sg+Abs:rsi # ;
+2PlPoss+Pl+Abs:si # ;
+3SgPoss+Sg+Abs:a # ;
+3SgPoss+Pl+Abs:i # ;
< %+3PlPoss:0 [ %+Sg:0 | %+Pl:0 ] %+Abs:{at} > # ;
< %+4SgPoss:0 [ %+Sg:0 | %+Pl:0 ] %+Abs:{mi} > # ;
+4PlPoss+Sg+Abs:rtik # ;
+4PlPoss+Pl+Abs:tik # ;

!Relativ
< %+1SgPoss:0 [ %+Sg:0 | %+Pl:0 ] %+Rel:{ma} > # ;
< %+1PlPoss:0 [ %+Sg:0 | %+Pl:0 ] %+Rel:{tta} > # ;
< %+2SgPoss:0 [ %+Sg:0 | %+Pl:0 ] 0:%^V2 %+Rel:{it} > # ;
< %+2PlPoss:0 [ %+Sg:0 | %+Pl:0 ] %+Rel:{ssi} > # ;
< [ %+3SgPoss:0 | %+3PlPoss:0 ] %+Sg:0 %+Rel:{ata} > # ;
< [ %+3SgPoss:0 | %+3PlPoss:0 ] %+Pl:0 %+Rel:{isa}  > # ;
< %+4PlPoss:0 [ %+Sg:0 | %+Pl:0 ] %+Rel:{mik} > # ;



