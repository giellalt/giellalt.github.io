Multichar_Symbols
+N +Sg +Pl +Abs +Rel +Lok +Ins
+V +IV +TV +Ind +Int
+1Sg +2Sg +3Sg +1Pl +2Pl +3Pl
+1PlO +1SgO +2PlO +2SgO +3PlO +3SgO 
^C ^GEM
+TUR


LEXICON Root
nouns ;
verbs ;

LEXICON nouns
illu svag "hus" ;
aja svag "moster" ;
isi svag "trommeskind" ;
qimmeq:qimmi QIMMEQ "hund" ;
nanoq:nanu QIMMEQ "bjørn" ;
taseq:tasi QIMMEQ "sø" ;
ukaleq:ukali QIMMEQ "hav" ;
ameq:ami QIMMEQ "hud" ;
< q e e r l u t o o q "+N":0 "+Abs":0 "+Sg":0 > # ; 

LEXICON verbs
! vokalstammer
anivoq:ani vok_stamme_iv "han går ud" ;
asavara:asa vok_stamme_tv "jeg elsker ham" ;
! konsonantstammer
toquppaa:toqu^C kns_stamme_tv "han dræbar ham" ;
naalappoq:naala^C kns_stamme_tv ;
! r-stammer
ajorpjor r_stamme "det duer ikke" ;



LEXICON svag
tilhæng ;
Kasus ;

 
LEXICON tilhæng
+TUR:%>tor r_stamme ;

LEXICON Kasus
+N+Abs+Sg: # ;
obliq ;

LEXICON obliq
+N+Rel+Sg:%>p # ;
+N+Lok+Sg:%>mi # ;
+N+Ins+Sg:%>mik # ;
+N+Abs+Pl:%>t # ;
+N+Rel+Pl:%>t # ;
+N+Lok+Pl:%>ni # ;
+N+Ins+Pl:%>nik # ;

LEXICON QIMMEQ
+N+Abs+Sg:^GEM%>q # ;
:^GEM obliq ;

LEXICON vok_stamme_iv
+V+IV: IVind_v ; ! indicative
+V+IV: IVint_v ; ! interrogative
+V+TV: TVind_v ; ! indicative
+V+TV: TVint_v ; ! interrogative

LEXICON kns_stamme_iv
+V+IV: vok_stamme_iv ;

LEXICON vok_stamme_tv
+V+TV: TVind_v ; ! indicative
+V+TV: TVint_v ; ! interrogative

LEXICON kns_stamme_tv 
vok_stamme_tv ;

LEXICON r_stamme #;

LEXICON IVind_v
+Ind+1Sg:%>vunga # ;
+Ind+2Sg:%>vutit # ; 
+Ind+3Sg:%>voq # ;
+Ind+1Pl:%>vugut # ;
+Ind+2Pl:%>vusi # ;
+Ind+3Pl:%>vupput # ;

LEXICON IVint_v
+Int+2Sg:%>vit # ; ! -it etter u
+Int+3Sg:%>va # ; ! -a etter u
+Int+2Pl:%>visi # ; ! isi etter u
+Int+3Pl:%>ppat # ;


LEXICON TVind_v
+Ind+2Sg+1SgO:%>varma  # ; ! asavarma, toqupparma
+Ind+3Sg+1SgO:%>vaanga  # ;
+Ind+2Pl+1SgO:%>vassinga  # ;
+Ind+3Pl+1SgO:%>vaannga  # ;

+Ind+1Sg+2SgO:%>vakkit  # ;
+Ind+3Sg+2SgO:%>vaatit  # ;
+Ind+1Pl+2SgO:%>vatsigit  # ;
+Ind+3Pl+2SgO:%>vaatsit  # ;

+Ind+1Sg+3SgO:%>vara  # ;
