+Ind+2Pl+3SgO:%>parsi  # ;
+Ind+3Pl+3SgO:%>paat  # ;

+Ind+2Sg+1PlO:%>patsigut  # ;
+Ind+3Sg+1PlO:%>paatsigut  # ;
