Multichar_Symbols
+N +Sg +Pl
+Abs +Rel +Lok + Ins +All +Abl +Via +Aeq
+V +IV +TV +Ind +Int
+1Sg +2Sg +3Sg +1Pl +2Pl +3Pl
^C ^GEM
@P.possAbsRel.ON@
@R.possAbsRel.ON@


LEXICON Root
nouns ; !ÆLDRE LEKSIKA - flyttet nederst på filen
verbs ; !ÆLDRE LEKSIKA - flyttet nederst på filen
nouns_2 ; !20300326 til Judithes sandkasse, separat bare så det er nemmere at overskue og for ikke at ødelægge de eksisterende leksika


LEXICON nouns_2 !svage og stærke stammer, svag: vokalstamme, svag q-stamme, svag k-stamme. stærke stammer: stærk q-stamme, stærk k-stamme. t-stammen

!svage stammer
!vokalstammer
aja svage_suff "moster (fra mors side)" ; !Z1VZmorf -> tpV -> tpV_infl
aqu svage_suff "bagende (af køretøj)" ; !Z1VZmorf
iki svage_suff "sår" ; !Z1VZmorf
inǝ svage_suff "rum eller værelse" ; !Z1eZmorf -> Z1eZ -> Z1eZ_inflections
!svage q-stammer
qimmeq svage_suff "hund" ; !Z1iqZmorf "strong i" -> tiqp	(bare 1 medlem i kal!!!)
meeraq svage_suff "barn" ; !Z1+qaZmorf -> Z1_qaZ_inflections (%VCTRUNC brugt i xfst)
igalaaq svage_suff "vindue" ; !Z1+ssZmorf -> Z1_ssZ_infl (%VCTRUNC igalaat + igalassat)
umiatsiaq svage_suff "båd" ; !Z1Zmorf -> tp_infl


LEXICON svage_suff !^T ved svage bøjninger
+N:^T poss ; !possessormarkeringer
+N:^T kasus ;


LEXICON poss
poss_Sg ;
poss_Pl ;

LEXICON poss_Sg
@P.possAbsRel.ON@ poss_kasus ;
+1SgPoss:%<^C
+2SgPoss:%<^C
+3SgPoss:%<a
+4SgPoss:%<ni

LEXICON poss_Pl
@P.possAbsRel.ON@ poss_kasus ; 
+1PlPoss:%<tsi^C
+2PlPoss:%<ssi^C
+3PlPoss:%<a^C
+4PlPoss:%<mi^C

LEXICON poss_kasus
@R.possAbsRel.ON@ poss_kasus_Oblique ;
poss_Sg_Abs_Rel ; !possessum singularis (possessor hvilken som helst - possessum dvs. selve nominet singularis) min moster, vores moster
poss_Pl_Abs_Rel ; !possessum pluralis (possessor hvilken som helst - possessum dvs. selve nominet pluralis) mine mostre, vores mostre

LEXICON poss_kasus_Oblique
< {nit} %+Abl [ %+Sg | %+Pl ] %<:0 > # ;
< {gut} %+Via [ %+Sg | %+Pl ] %<:0 > # ;
< {tut} %+Aeq [ %+Sg | %+Pl ] %<:0 > # ;
< {nik} %+Ins [ %+Sg | %+Pl ] %<:0 > # ;
< {nut} %+Trm [ %+Sg | %+Pl ] %<:0 > # ;
< {ni} %+Lok [ %+Sg | %+Pl ] %<:0 > # ;

LEXICON poss_Sg_Abs_Rel !possessum singularis
!1. person possessor
+1SgPoss+Abs+Sg:%<^Ga # ; !min moster
+1PlPoss+Abs+Sg:^T%<rput # ; !vores moster

+1SgPoss+Rel+Sg:^T%<ma # ; !min moster
+1PlPoss+Rel+Sg:^T%<tta # ; !vores moster

!2. person possessor
+2SgPoss+Abs+Sg:^T%<t # ;
+2PlPoss+Abs+Sg:^T%<rsi # ;

+2SgPoss+Rel+Sg:^T%<vit # ;
+2PlPoss+Rel+Sg:^T%<ssi # ;

!3. person possessor
+3SgPoss+Abs+Sg:^T%<a # ;
+3PlPoss+Abs+Sg:^T%<at # ;

+3SgPoss+Rel+Sg:^T%<ata # ;
+3PlPoss+Rel:^T%<i%<ta # ; !isa pga assibilering

!4. person possessor
+4SgPoss+Abs+Sg:^T%<ni # ;
+4PlPoss+Abs+Sg:^T%<rtik # ;


+4SgPoss+Rel:^T%<mi # ;

LEXICON poss_Pl_Abs_Rel !possessum pluralis
< {tta} [ %+1SgPoss | %+1PlPoss ] [ %+Abs | %+Rel ] [ %Sg | %+Pl ] 0:^T 0:%< > # ;
< {ssi} [ %+2SgPoss | %+2PlPoss ] [ %+Abs | %+Rel ] [ %Sg | %+Pl ] 0:^T 0:%< > # ;
+3PlPoss+Abs:%<ta
+3PlPoss+Rel:%<
+4PlPoss+Abs:%<
+4PlPoss+Rel:%<


!### Judithes oversigt og tjekliste ###!

