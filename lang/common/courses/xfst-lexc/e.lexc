!+N+Lok+Pl:%>ni # ;
!+N+Abl+Pl:%>nit # ;
!+N+Via+Pl:%>tigut # ;
!+N+Aeq+Pl:%>tut # ;
!
!
!
!
!LEXICON verbs
!! vokalstammer
!akivoq:aki vok_stamme_iv "han svarer" ;
!anivoq:ani vok_stamme_iv "han går ud" ;
!asavara:asa vok_stamme_tv "jeg elsker ham" ;
!! konsonantstammer
!xxxappoq.xxxaC kns_stamme_iv ;
!toquppaa:toqu^C kns_stamme_tv "han dræbar ham" ;
!naalappoq:naala^C kns_stamme_tv ;
!! r-stammer
!ajorpjor r_stamme "det duer ikke" ;
!
!
!
!LEXICON vok_stamme_iv
!+V+IV: IVind_v ; ! indicative
!+V+IV: IVint_v ; ! interrogative
!+V+TV: TVind_v ; ! indicative
!+V+TV: TVint_v ; ! interrogative
!
!LEXICON kns_stamme_iv
!vok_stamme_iv ;
!!+V+IV: IVind_k ; ! indicative
!!+V+IV: IVint_k ; ! interrogative
!!+V+TV: TVind_k ; ! indicative
!!+V+TV: TVint_k ; ! interrogative
!
!
!LEXICON vok_stamme_tv
!+V+TV: TVind_v ; ! indicative
!+V+TV: TVint_v ; ! interrogative
!
!LEXICON kns_stamme_tv
!vok_stamme_tv ;
!!+V+TV: TVind_k ; ! indicative
!!+V+TV: TVint_k ; ! interrogative
!
!
!LEXICON r_stamme #;
!
!LEXICON IVind_v
!+Ind+1Sg:%>vunga # ;
!+Ind+2Sg:%>vutit # ; 
!+Ind+3Sg:%>voq # ;
!+Ind+1Pl:%>vugut # ;
