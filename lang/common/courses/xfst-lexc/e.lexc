!### ÆLDRE LEKSIKA

!LEXICON nouns
!illu svag "hus" ;
!aja svag "moster" ;
!isi svag "trommeskind" ;
!qimmeq:qimmi QIMMEQ "hund" ;
!meeraq:meera^GEM  QIMMEQ "barn" ;
!nanoq:nanu svag "bjørn" ;
!
!
!LEXICON svag
!+N+Abs+Sg: # ;
!+N+Rel+Sg:%>p # ;
!+N+Ins+Sg:%>mik # ;
!+N+All+Sg:%>mut # ;
!+N+Lok+Sg:%>mi # ;
!+N+Abl+Sg:%>mit # ;
!+N+Via+Sg:%>kkut # ;
!+N+Aeq+Sg:%>tut # ;
!
